{
  "name": "Attendance Manager Dev Environment",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  "customizations": {
    "vscode": {
      "extensions": [
        "github.copilot",
        "github.copilot-chat",
        "ms-python.python"
      ]
    }
  },

  "postCreateCommand": "pip install -r backend/requirements.txt",

  "forwardPorts": [8000, 3000]
}
